{
  "id": "03_fp8_index_exact",
  "title": "FP8 Index Exact Search",
  "scope": "Indexer score kernel only",
  "goal": "Search exact implementations of the FP8 index score path while preserving identical output scores.",
  "depends_on": [
    "01_act_quant_exact"
  ],
