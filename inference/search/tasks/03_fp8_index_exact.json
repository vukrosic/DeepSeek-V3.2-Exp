    "Backend implementation"
  ],
  "forbidden_changes": [
    "Changing relu placement",
    "Changing scale application order",
    "Changing reduction semantics"
  ],
  "candidate_variants": [
    "Current exact CUDA fallback",
    "Exact batched matmul formulation",
    "Exact TileLang index kernel for Ampere",
    "Exact CUDA custom kernel"
  ]
}
